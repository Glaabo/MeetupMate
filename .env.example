# Database (local docker-compose default)
DATABASE_URL="postgresql://meetupmate:meetupmate@localhost:5432/meetupmate"

# Better Auth — generate with: npx auth secret
BETTER_AUTH_SECRET="change-me-run-npx-auth-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Optional: SMTP for magic-link sign-in (if unset, links are logged to the server console in development)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="MeetupMate <noreply@yourdomain.com>"

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Public app URL (used in invite links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
